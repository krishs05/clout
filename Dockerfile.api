FROM node:20-alpine

RUN apk add --no-cache openssl

WORKDIR /app

COPY package.json package-lock.json* ./
COPY packages packages
COPY apps apps
COPY turbo.json ./

RUN npm ci && npm run db:generate && npm run build

EXPOSE 3001

ENV NODE_ENV=production
CMD ["sh", "-c", "npm run db:push --workspace=@clout/database && npm run start --workspace=@clout/api"]
