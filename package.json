{
  "name": "clout",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "build:gh-pages": "npm run build:gh-pages --workspace=clout-web"
  },
  "devDependencies": {
    "@eslint/plugin-kit": "0.3.5",
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "turbo": "^2.8.14",
    "typescript": "^5.3.0",
    "undici": "6.23.0"
  },
  "overrides": {
    "undici": "6.23.0",
    "@eslint/plugin-kit": "0.3.5"
  },
  "packageManager": "npm@10.2.3",
  "engines": {
    "node": ">=20.9.0"
  }
}